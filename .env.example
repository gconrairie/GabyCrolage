# Fichier .env (non versionné) — dev local, build Docker et run Docker.
IG_ACCESS_TOKEN=
IG_USER_ID=

# Jeton pour le media kit : …/mk/<jeton> ou …/wk/<jeton> (alias)
# Inclus dans le bundle au build : garder une valeur forte.
VITE_MEDIA_KIT_SECRET=

# --- Docker / Docker Compose (+ Nginx Proxy Manager) ---
# Prérequis : fichier .env à la racine (secret de build + variables au run).
#   docker compose build && docker compose up -d
#
# NPM : Forward → http://gabycrolage-web:8080 (schéma http, pas https).
# Réseau Docker partagé : npm-graab (défini dans docker-compose.yml).
#
# Sans Compose : docker build --secret id=dotenv,src=.env -t gabycrolage:latest .
#   puis docker run -d --env-file .env --name gabycrolage-web -p 127.0.0.1:8080:8080 …
