# Fichier .env (non versionné) — dev local, build Docker et run Docker.
IG_ACCESS_TOKEN=
IG_USER_ID=

# Jeton pour l’URL du media kit : https://ton-domaine/fr/mk/<même-valeur>
# Inclus dans le bundle au build : garder une valeur forte.
VITE_MEDIA_KIT_SECRET=

# --- Docker / Docker Compose ---
# Prérequis : fichier .env à la racine (ce fichier est aussi la source du secret de build).
#   docker compose build
#   docker compose up -d
# Port hôte : 8080 par défaut ; surcharger avec WEB_PORT=80 par exemple.
#
# Sans Compose : docker build --secret id=dotenv,src=.env -t gabycrolage:latest .
#   puis docker run -d --env-file .env -p 8080:3000 --name gabycrolage --restart unless-stopped gabycrolage:latest
