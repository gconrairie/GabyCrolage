# Fichier .env (non versionné) — dev local, build Docker et run Docker.
IG_ACCESS_TOKEN=
IG_USER_ID=

# Jeton pour le media kit : …/mk/<jeton> ou …/wk/<jeton> (alias)
# Inclus dans le bundle au build : garder une valeur forte.
VITE_MEDIA_KIT_SECRET=

# --- Docker / Docker Compose (+ Nginx Proxy Manager) ---
# Fichier .env à la racine : Compose s’en sert pour injecter VITE_MEDIA_KIT_SECRET au *build*
# et pour le *run* (IG_*, etc.).
#   docker compose build --no-cache && docker compose up -d
#
# NPM : Forward → http://gabycrolage-web:8080 (schéma http, pas https).
# Réseau partagé : npm-graab.
#
# Sans Compose : docker build --build-arg VITE_MEDIA_KIT_SECRET=… -t gabycrolage:latest .
