# Copier vers .env — aussi configurés comme variables d’environnement sur Vercel (sans préfixe VITE_).
IG_ACCESS_TOKEN=
IG_USER_ID=

# Jeton secret pour l’URL du media kit : https://ton-domaine.fr/mk/<même-valeur>
# Générer une chaîne longue et imprévisible (ex. openssl rand -hex 24).
VITE_MEDIA_KIT_SECRET=
